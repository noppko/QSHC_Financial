        @section Scripts {
            @{
                await Html.RenderPartialAsync("_ValidationScriptsPartial");
            }
            <script>
                        function getDirectory() {
                            const input = document.getElementById('fileInput');
                            const directoryPath = input.files.length > 0 ? input.files[0].webkitRelativePath.split('/')[0] : '';
                            document.getElementById('directoryPath').innerText = 'Path Directory: ' + directoryPath;
                        }
            </script>
        }