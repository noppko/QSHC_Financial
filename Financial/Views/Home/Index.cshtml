@{
    ViewData["Title"] = "หน้าหลัก";
}

<style>
    .finexy-card {
        background-color: #1a1f2e;
        border: 1px solid #2d3748;
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.3s ease;
    }

    .finexy-card:hover {
        border-color: #ff7043;
        box-shadow: 0 4px 20px rgba(255, 112, 67, 0.15);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .card-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .card-icon {
        width: 40px;
        height: 40px;
        background: rgba(255, 112, 67, 0.1);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ff7043;
    }

    .card-title h2 {
        font-size: 20px;
        font-weight: 600;
        color: #f5f5f5;
    }

    .card-subtitle {
        font-size: 13px;
        color: #a0aec0;
        margin-top: 0.5rem;
    }

    .stat-box {
        background: rgba(255, 112, 67, 0.05);
        border: 1px solid rgba(255, 112, 67, 0.2);
        border-radius: 8px;
        padding: 1rem;
        margin-top: 1rem;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: #f5f5f5;
    }

    .stat-label {
        font-size: 12px;
        color: #a0aec0;
        margin-top: 0.25rem;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .chart-container {
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        height: 200px;
        margin-top: 1.5rem;
        padding-top: 1rem;
    }

    .chart-bar {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .bar {
        width: 30px;
        background: linear-gradient(180deg, #ff7043 0%, #ff8c5a 100%);
        border-radius: 4px 4px 0 0;
        transition: all 0.3s ease;
    }

    .bar:hover {
        opacity: 0.8;
    }

    .bar-label {
        font-size: 11px;
        color: #a0aec0;
        margin-top: 0.5rem;
    }

    .badge {
        display: inline-block;
        background: #ff7043;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge.success {
        background: rgba(76, 175, 80, 0.2);
        color: #4caf50;
    }

    .recent-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

    .recent-table th {
        background-color: rgba(255, 112, 67, 0.05);
        color: #a0aec0;
        padding: 0.75rem 1rem;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        border-bottom: 1px solid #2d3748;
    }

    .recent-table td {
        padding: 1rem;
        border-bottom: 1px solid #2d3748;
        color: #f5f5f5;
        font-size: 13px;
    }

    .recent-table tr:hover {
        background-color: rgba(255, 112, 67, 0.05);
    }
</style>

<!-- Main Dashboard Layout -->
<div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Total Balance Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">Total Balance</div>
        <div style="font-size: 28px; font-weight: 700; color: #f5f5f5;">$689,372.00</div>
        <div style="font-size: 12px; color: #4caf50; margin-top: 0.5rem;">
            <i class="fas fa-arrow-up"></i> 7.5% than last month
        </div>
    </div>

    <!-- Total Earnings Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">Total Earnings</div>
        <div style="font-size: 28px; font-weight: 700; color: #ff7043;">$950</div>
        <div style="font-size: 12px; color: #ff7043; margin-top: 0.5rem;">
            <i class="fas fa-arrow-up"></i> 5.7% This month
        </div>
    </div>

    <!-- Total Spending Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">Total Spending</div>
        <div style="font-size: 28px; font-weight: 700; color: #f5f5f5;">$700</div>
        <div style="font-size: 12px; color: #ff6b6b; margin-top: 0.5rem;">
            <i class="fas fa-arrow-down"></i> -5.5% This month
        </div>
    </div>
</div>

<!-- Secondary Stats Row -->
<div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Total Income Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">
            <i class="fas fa-arrow-up" style="color: #4caf50;"></i> Total Income
        </div>
        <div style="font-size: 24px; font-weight: 700; color: #f5f5f5;">$1,050</div>
        <div style="font-size: 11px; color: #a0aec0; margin-top: 0.5rem;">
            <span style="color: #4caf50;">↑ 9%</span> This month
        </div>
    </div>

    <!-- Revenue Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">
            <i class="fas fa-arrow-up" style="color: #4caf50;"></i> Revenue
        </div>
        <div style="font-size: 24px; font-weight: 700; color: #f5f5f5;">$850</div>
        <div style="font-size: 11px; color: #a0aec0; margin-top: 0.5rem;">
            <span style="color: #4caf50;">↑ 4.2%</span> This month
        </div>
    </div>

    <!-- Profit Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">Profit</div>
        <div style="font-size: 24px; font-weight: 700; color: #f5f5f5;">$350</div>
        <div style="font-size: 11px; color: #a0aec0; margin-top: 0.5rem; text-align: right;">
        </div>
    </div>

    <!-- Currency Card -->
    <div class="finexy-card">
        <div style="font-size: 12px; color: #a0aec0; margin-bottom: 0.5rem;">Currency</div>
        <div style="font-size: 24px; font-weight: 700; color: #f5f5f5;">
            <i class="fas fa-dollar-sign" style="color: #ff7043;"></i> USD
        </div>
        <div style="font-size: 11px; color: #a0aec0; margin-top: 0.5rem;">
            Primary
        </div>
    </div>
</div>

<!-- Charts and Activities Grid -->
<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
    <!-- Income Tracker Card -->
    <div class="finexy-card">
        <div class="card-header">
            <div class="card-title">
                <div class="card-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div>
                    <h2>Income Tracker</h2>
                    <p class="card-subtitle">Track your income trends over time</p>
                </div>
            </div>
            <select style="background-color: rgba(255, 112, 67, 0.1); border: 1px solid #2d3748; color: #f5f5f5; padding: 0.5rem; border-radius: 6px; cursor: pointer;">
                <option value="week">Week</option>
                <option value="month" selected>Month</option>
                <option value="year">Year</option>
            </select>
        </div>

        <div class="stat-box">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <div class="stat-value">$2,567</div>
                    <div class="stat-label">Total This Month</div>
                </div>
                <div style="text-align: right;">
                    <div style="font-size: 20px; color: #4caf50; font-weight: 600;">+20%</div>
                    <div style="font-size: 11px; color: #a0aec0;">Higher than last month</div>
                </div>
            </div>
        </div>

        <div class="chart-container">
            <div class="chart-bar">
                <div class="bar" style="height: 60px;"></div>
                <div class="bar-label">Mon</div>
            </div>
            <div class="chart-bar">
                <div class="bar" style="height: 90px;"></div>
                <div class="bar-label">Tue</div>
            </div>
            <div class="chart-bar">
                <div class="bar" style="height: 120px;"></div>
                <div class="bar-label">Wed</div>
            </div>
            <div class="chart-bar">
                <div class="bar" style="height: 100px;"></div>
                <div class="bar-label">Thu</div>
            </div>
            <div class="chart-bar">
                <div class="bar" style="height: 140px;"></div>
                <div class="bar-label">Fri</div>
            </div>
            <div class="chart-bar">
                <div class="bar" style="height: 110px;"></div>
                <div class="bar-label">Sat</div>
            </div>
            <div class="chart-bar">
                <div class="bar" style="height: 80px;"></div>
                <div class="bar-label">Sun</div>
            </div>
        </div>
    </div>

    <!-- Recent Activities Card -->
    <div class="finexy-card">
        <div class="card-header">
            <div class="card-title">
                <div class="card-icon">
                    <i class="fas fa-history"></i>
                </div>
                <div>
                    <h2>Recent Activities</h2>
                </div>
            </div>
        </div>

        <div style="space-y: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid #2d3748;">
                <div style="width: 40px; height: 40px; background: rgba(255, 112, 67, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #ff7043;">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div style="flex: 1; min-width: 0;">
                    <div style="font-size: 13px; color: #f5f5f5; font-weight: 500;">Shopping</div>
                    <div style="font-size: 12px; color: #a0aec0;">Just now</div>
                </div>
                <div style="font-size: 13px; font-weight: 600; color: #ff7043;">-$45.00</div>
            </div>

            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid #2d3748;">
                <div style="width: 40px; height: 40px; background: rgba(76, 175, 80, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #4caf50;">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div style="flex: 1; min-width: 0;">
                    <div style="font-size: 13px; color: #f5f5f5; font-weight: 500;">Income</div>
                    <div style="font-size: 12px; color: #a0aec0;">2 hours ago</div>
                </div>
                <div style="font-size: 13px; font-weight: 600; color: #4caf50;">+$250.00</div>
            </div>

            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid #2d3748;">
                <div style="width: 40px; height: 40px; background: rgba(33, 150, 243, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #2196f3;">
                    <i class="fas fa-plane"></i>
                </div>
                <div style="flex: 1; min-width: 0;">
                    <div style="font-size: 13px; color: #f5f5f5; font-weight: 500;">Travel</div>
                    <div style="font-size: 12px; color: #a0aec0;">Yesterday</div>
                </div>
                <div style="font-size: 13px; font-weight: 600; color: #ff7043;">-$150.00</div>
            </div>

            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0;">
                <div style="width: 40px; height: 40px; background: rgba(255, 112, 67, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #ff7043;">
                    <i class="fas fa-utensils"></i>
                </div>
                <div style="flex: 1; min-width: 0;">
                    <div style="font-size: 13px; color: #f5f5f5; font-weight: 500;">Dining</div>
                    <div style="font-size: 12px; color: #a0aec0;">3 days ago</div>
                </div>
                <div style="font-size: 13px; font-weight: 600; color: #ff7043;">-$65.00</div>
            </div>
        </div>
    </div>
</div>

