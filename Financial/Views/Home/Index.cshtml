@{
    ViewData["Title"] = "หน้าหลัก";
}

<style>
    .card {
        background: var(--card);
        border-radius: var(--radius-xl);
        padding: 22px;
    }

    .label {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--ink-2);
    }

    /* -------- GRID LAYOUT -------- */
    .grid {
        display: grid;
        gap: 20px;
        grid-template-columns: minmax(300px, 380px) minmax(380px, 1fr) minmax(340px, 390px);
        grid-template-areas:
            "balance stats income"
            "limit  recent recent"
            "cards  recent recent";
        align-items: start;
    }

    /* -------- TOTAL BALANCE -------- */
    .balance {
        grid-area: balance;
    }

    .balance-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .currency {
        display: flex;
        align-items: center;
        gap: 7px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
    }

    .flag {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #3C3B6E;
        display: block;
    }

    .balance-amount {
        font-size: 38px;
        font-weight: 700;
        letter-spacing: -1px;
        margin: 14px 0 8px;
    }

    .trend {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12.5px;
        color: var(--muted);
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: 11.5px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 999px;
    }

    .badge.up {
        background: #E8F7EF;
        color: var(--green);
    }

    .badge.down {
        background: #FDEBEA;
        color: var(--red);
    }

    .balance-actions {
        display: flex;
        gap: 10px;
        margin: 18px 0;
    }

    .btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px;
        border-radius: 999px;
        border: none;
        font-size: 14.5px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: filter .15s;
    }

    .btn:hover {
        filter: brightness(0.95);
    }

    .btn-dark {
        background: var(--ink);
        color: #fff;
    }

    .btn-light {
        background: var(--card-soft);
        color: var(--ink);
    }

    .wallets {
        background: var(--card-soft);
        border-radius: var(--radius-lg);
        padding: 16px;
    }

    .wallets-head {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13.5px;
        margin-bottom: 12px;
    }

    .wallets-head b {
        font-weight: 700;
    }

    .wallets-head span {
        color: var(--muted);
    }

    .wallets-head .sep {
        color: #D6D6D3;
    }

    .wallet-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .wallet {
        background: #fff;
        border-radius: var(--radius-md);
        padding: 12px 10px;
        position: relative;
    }

    .wallet-cur {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12.5px;
        font-weight: 700;
    }

    .wallet-amt {
        font-size: 14px;
        font-weight: 700;
        margin: 8px 0 3px;
        letter-spacing: -.2px;
    }

    .wallet-limit {
        font-size: 9.5px;
        color: var(--muted);
    }

    .wallet-status {
        font-size: 10px;
        font-weight: 600;
        margin-top: 7px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .wallet-status::before {
        content: "";
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    .wallet-status.active {
        color: var(--green);
    }

    /* -------- STATS 2x2 -------- */
    .stats {
        grid-area: stats;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .stat {
        background: var(--card);
        border-radius: var(--radius-xl);
        padding: 22px;
        min-height: 170px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .stat.hero {
        background: linear-gradient(150deg, #FF8A50 0%, var(--orange) 55%, #E8430F 100%);
        color: #fff;
    }

    .stat-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-title {
        font-size: 14.5px;
        font-weight: 600;
    }

    .stat.hero .stat-title {
        color: #fff;
    }

    .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--card-soft);
        display: grid;
        place-items: center;
        color: var(--ink-2);
    }

    .stat.hero .stat-icon {
        background: rgba(255, 255, 255, .22);
        color: #fff;
    }

    .stat-icon svg {
        width: 17px;
        height: 17px;
    }

    .stat-amount {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -.5px;
        margin-top: 20px;
    }

    .stat-foot {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 10px;
        font-size: 12.5px;
        color: var(--muted);
    }

    .stat.hero .stat-foot {
        color: rgba(255, 255, 255, .85);
    }

    .stat.hero .badge {
        background: rgba(255, 255, 255, .25);
        color: #fff;
    }

    /* -------- INCOME CHART -------- */
    .income {
        grid-area: income;
    }

    .income h3 {
        font-size: 17px;
        font-weight: 700;
    }

    .income .sub {
        font-size: 12.5px;
        color: var(--muted);
        margin: 5px 0 16px;
    }

    .chart-card {
        background: var(--card-soft);
        border-radius: var(--radius-lg);
        padding: 16px;
    }

    .chart-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .chart-title {
        font-size: 13.5px;
        font-weight: 700;
    }

    .legend {
        display: flex;
        gap: 14px;
        font-size: 11.5px;
        color: var(--ink-2);
    }

    .legend span {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .legend i {
        width: 9px;
        height: 9px;
        border-radius: 3px;
        display: inline-block;
    }

    .legend .profit i {
        background: var(--orange);
    }

    .legend .loss i {
        background: var(--ink);
    }

    .chart {
        display: flex;
        gap: 4px;
    }

    .bars {
        flex: 1;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        height: 190px;
    }

    .bar-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 24px;
    }

    .bar-stack {
        position: relative;
        width: 22px;
        height: 172px;
    }

    .bar {
        position: absolute;
        left: 0;
        width: 100%;
        border-radius: 7px;
    }

    .bar.profit {
        background: var(--orange);
    }

    .bar.loss {
        background: var(--ink);
    }

    .x-label {
        font-size: 10px;
        color: var(--muted);
        margin-top: 8px;
    }

    /* -------- SPENDING LIMIT -------- */
    .limit {
        grid-area: limit;
    }

    .limit h3 {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .progress {
        height: 12px;
        border-radius: 999px;
        overflow: hidden;
        background: #EFEFEC;
    }

    .progress i {
        display: block;
        height: 100%;
        width: 26%;
        background: var(--orange);
        border-radius: 999px;
    }

    .limit-foot {
        display: flex;
        justify-content: space-between;
        margin-top: 12px;
        font-size: 12.5px;
        color: var(--muted);
    }

    .limit-foot b {
        color: var(--ink);
        font-weight: 700;
        font-size: 13px;
    }

    /* -------- MY CARDS -------- */
    .mycards {
        grid-area: cards;
    }

    .mycards-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .mycards-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: 700;
    }

    .mycards-title .stat-icon {
        width: 34px;
        height: 34px;
    }

    .addnew {
        background: var(--card-soft);
        border: none;
        border-radius: 999px;
        padding: 10px 16px;
        font-family: inherit;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .addnew:hover {
        background: #ECECEA;
    }

    .cards-row {
        display: flex;
        gap: 12px;
        overflow: hidden;
    }

    .bank-card {
        min-width: 230px;
        flex: 1;
        border-radius: 20px;
        padding: 16px;
        color: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 150px;
        position: relative;
    }

    .bank-card.black {
        background: linear-gradient(145deg, #2A2A27, #151513);
    }

    .bank-card.orange {
        background: linear-gradient(145deg, #FF8A50, #F4551F);
        min-width: 150px;
        flex: 0 0 46%;
    }

    .bc-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .chip-active {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, .16);
        border-radius: 999px;
        padding: 5px 12px 5px 8px;
        font-size: 11px;
        font-weight: 600;
    }

    .chip-icon {
        width: 16px;
        height: 16px;
        border-radius: 4px;
        background: linear-gradient(135deg, #FFD700, #FFA500);
    }

    .bc-bottom {
        display: flex;
        gap: 18px;
        font-size: 11px;
    }

    .bc-field span {
        display: block;
        color: rgba(255, 255, 255, .65);
        font-size: 9.5px;
        margin-bottom: 4px;
    }

    .bc-field b {
        font-weight: 600;
        letter-spacing: .5px;
    }

    /* -------- RECENT ACTIVITIES -------- */
    .recent {
        grid-area: recent;
    }

    .recent-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 14px;
        flex-wrap: wrap;
    }

    .recent-head h3 {
        font-size: 19px;
        font-weight: 700;
    }

    .recent-tools {
        display: flex;
        gap: 10px;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 10px 16px;
        width: 220px;
        color: var(--muted);
    }

    .search-box input {
        border: none;
        outline: none;
        font-family: inherit;
        font-size: 13.5px;
        width: 100%;
        background: transparent;
        color: var(--ink);
    }

    .filter-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        background: #fff;
        border-radius: 999px;
        padding: 10px 18px;
        font-family: inherit;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
    }

    .filter-btn:hover {
        background: var(--card-soft);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13.5px;
    }

    thead th {
        text-align: left;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--muted);
        background: var(--card-soft);
        padding: 13px 14px;
    }

    thead th:first-child {
        border-radius: 12px 0 0 12px;
        width: 44px;
    }

    thead th:last-child {
        border-radius: 0 12px 12px 0;
        width: 44px;
    }

    tbody td {
        padding: 16px 14px;
        border-bottom: 1px solid var(--line);
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    .act {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
    }

    .act-ic {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-weight: 500;
        color: var(--ink-2);
    }

    .status::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .status.done::before {
        background: var(--green);
    }

    .status.pending::before {
        background: var(--red);
    }

    .status.progress::before {
        background: var(--yellow);
    }

    .date-cell {
        color: var(--ink-2);
    }

    @@media (max-width: 1200px) {
        .grid {
            grid-template-columns: 1fr 1fr;
            grid-template-areas:
                "balance stats" "income income" "limit cards" "recent recent";
        }
    }

    @@media (max-width: 820px) {
        .grid {
            grid-template-columns: 1fr;
            grid-template-areas: "balance" "stats" "income" "limit" "cards" "recent";
        }

        .recent {
            overflow-x: auto;
        }

        table {
            min-width: 720px;
        }
    }
</style>

<!-- ================= MAIN GRID ================= -->
<main class="grid">

    <!-- Total Balance -->
    <section class="card balance">
        <div class="balance-head">
            <span class="label">Total Balance</span>
            <button class="currency">
                <span class="flag"></span>
                USD
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <path d="M6 9l6 6 6-6" />
                </svg>
            </button>
        </div>
        <div class="balance-amount">$689,372.00</div>
        <div class="trend"><span class="badge up">↑ 5%</span> than last month</div>

        <div class="balance-actions">
            <button class="btn btn-dark">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 10h13m0 0l-3-3m3 3l-3 3M17 14H4m0 0l3 3m-3-3l3-3" />
                </svg>
                Transfer
            </button>
            <button class="btn btn-light">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 10h13m0 0l-3-3m3 3l-3 3M17 14H4m0 0l3 3m-3-3l3-3" />
                </svg>
                Request
            </button>
        </div>

        <div class="wallets">
            <div class="wallets-head"><b>Wallets</b><span class="sep">|</span><span>Total 6 wallets</span></div>
            <div class="wallet-row">
                <div class="wallet">
                    <div class="wallet-cur">🇺🇸 USD</div>
                    <div class="wallet-amt">$22,678.00</div>
                    <div class="wallet-limit">Limit is $10k a month</div>
                    <div class="wallet-status active">Active</div>
                </div>
                <div class="wallet">
                    <div class="wallet-cur">🇪🇺 EUR</div>
                    <div class="wallet-amt">€18,345.00</div>
                    <div class="wallet-limit">Limit is €8k a month</div>
                    <div class="wallet-status active">Active</div>
                </div>
                <div class="wallet">
                    <div class="wallet-cur">🇬🇧 GBP</div>
                    <div class="wallet-amt">£15,000.00</div>
                    <div class="wallet-limit">Limit is £7.5k a month</div>
                    <div class="wallet-status active">Active</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats 2x2 -->
    <section class="stats">
        <div class="stat hero">
            <div class="stat-head">
                <span class="stat-title">Total Earnings</span>
                <span class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="7" width="18" height="13" rx="3" />
                        <path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" />
                        <path d="M3 12h18" />
                    </svg>
                </span>
            </div>
            <div>
                <div class="stat-amount">$950</div>
                <div class="stat-foot"><span class="badge">↑ 7%</span> This month</div>
            </div>
        </div>

        <div class="stat">
            <div class="stat-head">
                <span class="stat-title">Total Spending</span>
                <span class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 3h12l1 5H5l1-5z" />
                        <rect x="5" y="8" width="14" height="13" rx="2" />
                        <path d="M9 12a3 3 0 006 0" />
                    </svg>
                </span>
            </div>
            <div>
                <div class="stat-amount">$700</div>
                <div class="stat-foot"><span class="badge down">↓ 5%</span> This month</div>
            </div>
        </div>

        <div class="stat">
            <div class="stat-head">
                <span class="stat-title">Total Income</span>
                <span class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <ellipse cx="12" cy="6" rx="7" ry="3" />
                        <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6" />
                        <path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />
                    </svg>
                </span>
            </div>
            <div>
                <div class="stat-amount">$1,050</div>
                <div class="stat-foot"><span class="badge up">↑ 8%</span> This month</div>
            </div>
        </div>

        <div class="stat">
            <div class="stat-head">
                <span class="stat-title">Total Revenue</span>
                <span class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3c-4 3-6 5.5-6 9a6 6 0 0012 0c0-3.5-2-6-6-9z" />
                        <path d="M9 4h6" />
                    </svg>
                </span>
            </div>
            <div>
                <div class="stat-amount">$850</div>
                <div class="stat-foot"><span class="badge up">↑ 4%</span> This month</div>
            </div>
        </div>
    </section>

    <!-- Total Income chart -->
    <section class="card income">
        <h3>Total Income</h3>
        <p class="sub">View your income in a certain period of time</p>
        <div class="chart-card">
            <div class="chart-head">
                <span class="chart-title">Profit and Loss</span>
                <div class="legend">
                    <span class="profit"><i></i>Profit</span>
                    <span class="loss"><i></i>Loss</span>
                </div>
            </div>
            <div class="chart">
                <div class="bars">
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 80px;"></div>
                            <div class="bar loss" style="bottom: 80px; height: 40px;"></div>
                        </div>
                        <div class="x-label">Jan</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 95px;"></div>
                            <div class="bar loss" style="bottom: 95px; height: 35px;"></div>
                        </div>
                        <div class="x-label">Feb</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 110px;"></div>
                            <div class="bar loss" style="bottom: 110px; height: 30px;"></div>
                        </div>
                        <div class="x-label">Mar</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 90px;"></div>
                            <div class="bar loss" style="bottom: 90px; height: 45px;"></div>
                        </div>
                        <div class="x-label">Apr</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 120px;"></div>
                            <div class="bar loss" style="bottom: 120px; height: 28px;"></div>
                        </div>
                        <div class="x-label">May</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 105px;"></div>
                            <div class="bar loss" style="bottom: 105px; height: 38px;"></div>
                        </div>
                        <div class="x-label">Jun</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 115px;"></div>
                            <div class="bar loss" style="bottom: 115px; height: 32px;"></div>
                        </div>
                        <div class="x-label">Jul</div>
                    </div>
                    <div class="bar-col">
                        <div class="bar-stack">
                            <div class="bar profit" style="bottom: 0; height: 100px;"></div>
                            <div class="bar loss" style="bottom: 100px; height: 42px;"></div>
                        </div>
                        <div class="x-label">Aug</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Monthly Spending Limit -->
    <section class="card limit">
        <h3>Monthly Spending Limit</h3>
        <div class="progress"><i></i></div>
        <div class="limit-foot">
            <span><b>$1,400.00</b> spent out of</span>
            <b>$5,500.00</b>
        </div>
    </section>

    <!-- My Cards -->
    <section class="card mycards">
        <div class="mycards-head">
