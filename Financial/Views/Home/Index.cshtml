                <td style="display: flex; align-items: center; gap: 0.5rem;">
                    <div style="width: 24px; height: 24px; background: rgba(76, 175, 80, 0.2); border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #4caf50; font-size: 10px;">
                        <i class="fas fa-arrow-down"></i>
                    </div>
                    Income
                </td>
                <td style="color: #4caf50; font-weight: 600;">+$750.00</td>
                <td><span class="badge success">Completed</span></td>
                <td>14 Apr, 2026</td>
            </tr>
        </tbody>
    </table>
</div>
