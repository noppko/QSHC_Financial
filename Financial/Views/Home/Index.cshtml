@{
    ViewData["Title"] = "หน้าหลัก";
}

<!-- Welcome Section -->
<div class="mb-8">
    <div class="bg-gradient-to-r from-primary-600 to-primary-800 rounded-2xl p-8 text-white shadow-xl">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h1 class="text-3xl font-bold mb-2">
                    <i class="fas fa-hand-sparkles mr-3"></i>สวัสดี, @(User.Identity?.IsAuthenticated == true ? User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value : "ผู้ใช้งาน")
                </h1>
                <p class="text-primary-100">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span>@User.Claims.FirstOrDefault(c => c.Type == "JobPosition")?.Value</span>
                        <span class="mx-2">•</span>
                    }
                    <span>วันที่ @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("th-TH"))</span>
                </p>
            </div>
            <div class="text-right">
                <div class="text-5xl font-bold">@DateTime.Now.ToString("HH:mm")</div>
                <div class="text-sm text-primary-200">เวลาปัจจุบัน</div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Card 1: IPD Discharges -->
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-bed text-blue-600 text-xl"></i>
            </div>
            <span class="text-2xl font-bold text-gray-800">---</span>
        </div>
        <h3 class="text-gray-600 text-sm font-medium mb-1">D/C IPD</h3>
        <p class="text-xs text-gray-400">ผู้ป่วยในที่จำหน่ายวันนี้</p>
    </div>

    <!-- Card 2: OPD Discharges -->
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-user-injured text-green-600 text-xl"></i>
            </div>
            <span class="text-2xl font-bold text-gray-800">---</span>
        </div>
        <h3 class="text-gray-600 text-sm font-medium mb-1">D/C OPD</h3>
        <p class="text-xs text-gray-400">ผู้ป่วยนอกที่จำหน่ายวันนี้</p>
    </div>

    <!-- Card 3: Total Amount -->
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-purple-500 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-dollar-sign text-purple-600 text-xl"></i>
            </div>
            <span class="text-2xl font-bold text-gray-800">---</span>
        </div>
        <h3 class="text-gray-600 text-sm font-medium mb-1">จำนวนเงินรวม</h3>
        <p class="text-xs text-gray-400">ยอดรวมวันนี้ (บาท)</p>
    </div>

    <!-- Card 4: EDC Interface -->
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-orange-500 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-exchange-alt text-orange-600 text-xl"></i>
            </div>
            <span class="text-2xl font-bold text-gray-800">---</span>
        </div>
        <h3 class="text-gray-600 text-sm font-medium mb-1">EDC Interface</h3>
        <p class="text-xs text-gray-400">ไฟล์ที่ประมวลผลแล้ว</p>
    </div>
</div>

<!-- Quick Actions -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Left: Quick Access -->
    <div class="card">
        <h2 class="card-header">
            <i class="fas fa-bolt mr-2 text-primary-600"></i>เมนูด่วน
        </h2>
        <div class="grid grid-cols-2 gap-4">
            <a asp-controller="Discharges" asp-action="IPD" 
               class="flex flex-col items-center justify-center p-6 bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl hover:from-blue-100 hover:to-blue-200 transition-all duration-300 group">
                <i class="fas fa-bed text-4xl text-blue-600 mb-3 group-hover:scale-110 transition-transform"></i>
                <span class="text-sm font-medium text-gray-700">D/C IPD</span>
            </a>
            <a asp-controller="Discharges" asp-action="OPD" 
               class="flex flex-col items-center justify-center p-6 bg-gradient-to-br from-green-50 to-green-100 rounded-xl hover:from-green-100 hover:to-green-200 transition-all duration-300 group">
                <i class="fas fa-user-injured text-4xl text-green-600 mb-3 group-hover:scale-110 transition-transform"></i>
                <span class="text-sm font-medium text-gray-700">D/C OPD</span>
            </a>
            <a asp-controller="InterfaceSystem" asp-action="EDCIndex" 
               class="flex flex-col items-center justify-center p-6 bg-gradient-to-br from-orange-50 to-orange-100 rounded-xl hover:from-orange-100 hover:to-orange-200 transition-all duration-300 group">
                <i class="fas fa-exchange-alt text-4xl text-orange-600 mb-3 group-hover:scale-110 transition-transform"></i>
                <span class="text-sm font-medium text-gray-700">EDC Interface</span>
            </a>
            <a asp-controller="InterfaceSystem" asp-action="Index" 
               class="flex flex-col items-center justify-center p-6 bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl hover:from-purple-100 hover:to-purple-200 transition-all duration-300 group">
                <i class="fas fa-cogs text-4xl text-purple-600 mb-3 group-hover:scale-110 transition-transform"></i>
                <span class="text-sm font-medium text-gray-700">Interface System</span>
            </a>
        </div>
    </div>

    <!-- Right: System Info -->
    <div class="card">
        <h2 class="card-header">
            <i class="fas fa-info-circle mr-2 text-primary-600"></i>ข้อมูลระบบ
        </h2>
        <div class="space-y-4">
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                <div class="flex items-center space-x-3">
                    <i class="fas fa-code-branch text-primary-600 text-xl"></i>
                    <div>
                        <p class="text-sm font-medium text-gray-700">เวอร์ชันระบบ</p>
                        <p class="text-xs text-gray-500">.NET 10.0</p>
                    </div>
                </div>
                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Active</span>
            </div>

            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                <div class="flex items-center space-x-3">
                    <i class="fas fa-database text-blue-600 text-xl"></i>
                    <div>
                        <p class="text-sm font-medium text-gray-700">ฐานข้อมูล</p>
                        <p class="text-xs text-gray-500">SQL Server</p>
                    </div>
                </div>
                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Connected</span>
            </div>

            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                <div class="flex items-center space-x-3">
                    <i class="fas fa-user-shield text-purple-600 text-xl"></i>
                    <div>
                        <p class="text-sm font-medium text-gray-700">การยืนยันตัวตน</p>
                        <p class="text-xs text-gray-500">External Auth API</p>
                    </div>
                </div>
                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Secure</span>
            </div>
        </div>
    </div>
</div>

<!-- Recent Updates Info -->
<div class="card bg-gradient-to-r from-gray-50 to-gray-100 border border-gray-200">
    <div class="flex items-start space-x-4">
        <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center flex-shrink-0">
            <i class="fas fa-rocket text-white text-xl"></i>
        </div>
        <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-800 mb-2">ระบบอัปเดตเป็น .NET 10</h3>
            <p class="text-sm text-gray-600 mb-3">
                ระบบได้รับการอัปเกรดเป็น .NET 10.0 พร้อมฟีเจอร์ใหม่และการปรับปรุงประสิทธิภาพ:
            </p>
            <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex items-center">
                    <i class="fas fa-check-circle text-green-600 mr-2"></i>
                    <span>Authentication ผ่าน External API</span>
                </li>
                <li class="flex items-center">
                    <i class="fas fa-check-circle text-green-600 mr-2"></i>
                    <span>ปรับปรุง UI/UX ด้วย Tailwind CSS</span>
                </li>
                <li class="flex items-center">
                    <i class="fas fa-check-circle text-green-600 mr-2"></i>
                    <span>เพิ่ม Logging ด้วย Serilog</span>
                </li>
                <li class="flex items-center">
                    <i class="fas fa-check-circle text-green-600 mr-2"></i>
                    <span>รองรับการ Export Excel และ PDF</span>
                </li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add animation on page load
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.card, .bg-white');
            cards.forEach((card, index) => {
                setTimeout(() => {
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    card.style.transition = 'all 0.5s ease-out';
                    
                    requestAnimationFrame(() => {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    });
                }, index * 100);
            });
        });

        // Update time every second
        setInterval(() => {
            const now = new Date();
            const timeStr = now.getHours().toString().padStart(2, '0') + ':' + 
                          now.getMinutes().toString().padStart(2, '0');
            const timeElement = document.querySelector('.text-5xl');
            if (timeElement) {
                timeElement.textContent = timeStr;
            }
        }, 1000);
    </script>
}

