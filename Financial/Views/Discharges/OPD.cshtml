@model IEnumerable<Financial.Models.ViewModels.VmDischargesPD>

@{
    ViewData["Title"] = "Discharge OPD";
}

<!-- Page Header -->
<div class="bg-white rounded-3xl shadow-lg p-6 mb-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 mb-2">Export Discharge OPD</h1>
            <p class="text-sm text-gray-500">ข้อมูลผู้ป่วยนอกที่จำหน่าย: @ViewBag.fSdate ถึง @ViewBag.fEdate</p>
        </div>
        <a href="@Url.Action("ExportExcelOP", "Discharges", new { start = ViewBag.StartDate, end = ViewBag.EndDate })"
           class="px-6 py-3 bg-amber-600 text-white rounded-xl hover:bg-amber-700 transition-colors inline-flex items-center space-x-2">
            <i class="fas fa-file-excel"></i>
            <span>Export Excel</span>
        </a>
    </div>

    <!-- Search Form -->
    <form asp-controller="Discharges" asp-action="OPD"
          class="bg-gradient-to-r from-amber-50 to-yellow-50 rounded-2xl p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-calendar-alt mr-2 text-amber-600"></i>จากวันที่
                </label>
                <input type="date" name="start" class="input-field" value="@ViewBag.StartDate">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-calendar-alt mr-2 text-amber-600"></i>ถึงวันที่
                </label>
                <input type="date" name="end" class="input-field" value="@ViewBag.EndDate">
            </div>
            <div>
                <button type="submit" class="w-full btn-primary bg-amber-600 hover:bg-amber-700">
                    <i class="fas fa-search mr-2"></i>ค้นหา
                </button>
            </div>
        </div>
    </form>
</div>


<!-- Data Table -->
<div class="bg-white rounded-3xl shadow-lg overflow-hidden">
    <div class="overflow-x-auto">
        <table id="dischargeTable" class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">ลำดับ
                    </th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                        ชื่อ-สกุล</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">สิทธิ์
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">BillCon
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">HN</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">VN</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">D/C
                        </th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider">
                            จำนวนเงิน</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Clinic
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fas fa-inbox text-4xl mb-3 text-gray-300"></i>
                                    <p>ไม่พบข้อมูลที่ค้นหา</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.Id</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@item.FullName</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.TreatmentRight</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.BillCon</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.HN</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.AN</td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.DCDate)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Amount)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Clinic)
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                @if (Model != null)
                {
                    <form id="ExportExcelOP" asp-action="ExportExcelOP" asp-route-start="@ViewBag.fSdate"
                          asp-route-end="@ViewBag.fEdate" asp-route-dep="@ViewBag.Coldep"></form>
                    <button type="submit" form="ExportExcelOP" class="btn btn-warning btn-lg">Export To Excel</button>

                }

                @section Scripts {
                    @{
                        await Html.RenderPartialAsync("_ValidationScriptsPartial");
                    }

                }
