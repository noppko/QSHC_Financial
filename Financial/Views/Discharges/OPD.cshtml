@model IEnumerable<Financial.Models.ViewModels.VmDischargesPD>

@{
    ViewData["Title"] = "OPD";
}
@*<h2>@ViewData["Title"]</h2>*@
<h1>Export Discharge OPD</h1>

<div class="alert alert-warning" role="alert">
    <h5>เงื่อนไขการค้นหาข้อมูล จากวันที่ :  @ViewBag.fSdate ถึงวันที่ : @ViewBag.fEdate</h5>
    <hr />


    <form asp-controller="Discharges" asp-action="OPD">
        <div class="row">

            <div class="form-group row col-6">
                <label class="col-sm-3 col-form-label">จากวันที่ :</label>
                <div class="col-sm-8">
                    <input type="date" name="start" class="col-sm-4 form-control">
                </div>
            </div>
            <div class="form-group row  col-6">
                <label class="col-sm-3 col-form-label">ถึงวันที่ :</label>
                <div class="col-sm-8">
                    <input type="date" name="end" class="col-sm-4 form-control">
                </div>
            </div>
        </div>
        <div class="form-group">
            <input class="btn btn-warning" type="submit" value="ค้นหา" />
        </div>

    </form>
</div>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TreatmentRight)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BillCon)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HN)
            </th>
            <th>
                VN
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DCDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Amount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Clinic)
            </th>
        </tr>
    </thead>
    <tbody>
         @if (Model == null)
        {
            <tr>
            <td class="text-center" colspan="9">
                ไม่พบข้อมูลที่ค้นหา
            </td>
            </tr>
        }else
        {
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FullName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TreatmentRight)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BillCon)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.HN)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.AN)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DCDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Amount)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Clinic)
                </td>
            </tr>
        }
        }
    </tbody>
</table>
@if (Model != null)
{
    <form id="ExportExcelOP" asp-action="ExportExcelOP" asp-route-start="@ViewBag.fSdate" asp-route-end="@ViewBag.fEdate" asp-route-dep="@ViewBag.Coldep"></form>
    <button type="submit" form="ExportExcelOP" class="btn btn-warning btn-lg">Export To Excel</button>

}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    }
