@model IEnumerable<Financial.Models.ViewModels.VmDischargesPD>

@{
    ViewData["Title"] = "IPD";
}
@*<h2>@ViewData["Title"]</h2>*@
<h1>Export Discharge IPD</h1>

<div class="alert alert-success" role="alert">
    <h5>เงื่อนไขการค้นหาข้อมูล จากวันที่ :  @ViewBag.fSdate ถึงวันที่ : @ViewBag.fEdate</h5>
    <hr />


    <form asp-controller="Discharges" asp-action="IPD">
        <div class="row">

            <div class="form-group row col-6">
                <label class="col-sm-3 col-form-label">จากวันที่ :</label>
                <div class="col-sm-8">
                    <input type="date" name="start" class="col-sm-4 form-control">
                </div>
            </div>
            <div class="form-group row  col-6">
                <label class="col-sm-3 col-form-label">ถึงวันที่ :</label>
                <div class="col-sm-8">
                    <input type="date" name="end" class="col-sm-4 form-control">
                </div>
            </div>
        </div>
        <div class="form-group">
            <input class="btn btn-success" type="submit" value="ค้นหา" />
        </div>

    </form>
</div>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TreatmentRight)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HN)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AN)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admit)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DCDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Amount)
            </th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null)
        {
            <tr>
                <td class="text-center" colspan="8">
                    ไม่พบข้อมูลที่ค้นหา
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.FullName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.TreatmentRight)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.HN)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.AN)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Admit)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DCDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Amount)
                    </td>
                </tr>
            }
        }

    </tbody>
</table>

@if (Model != null)
{
    <form id="ExportExcelIP" asp-action="ExportExcelIP" asp-route-start="@ViewBag.fSdate" asp-route-end="@ViewBag.fEdate" asp-route-dep="@ViewBag.Coldep"></form>
    <button type="submit" form="ExportExcelIP" class="btn btn-success btn-lg">Export To Excel</button>
}


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(function () {
            $("#example1").DataTable({
                "responsive": true, "lengthChange": false, "autoWidth": false,
                "buttons": ["copy", "csv", "excel", "pdf", "print", "colvis"]
            }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
            $('#example2').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": false,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });
        });
    </script>


    }
