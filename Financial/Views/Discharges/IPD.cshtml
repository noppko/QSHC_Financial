@model IEnumerable<Financial.Models.ViewModels.VmDischargesPD>

@{
    ViewData["Title"] = "Discharge IPD";
}

<!-- Page Header -->
<div class="bg-white rounded-3xl shadow-lg p-6 mb-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 mb-2">Export Discharge IPD</h1>
            <p class="text-sm text-gray-500">ข้อมูลผู้ป่วยในที่จำหน่าย: @ViewBag.fSdate ถึง @ViewBag.fEdate</p>
        </div>
        <a href="@Url.Action("ExportExcelIP", "Discharges", new { start = ViewBag.StartDate, end = ViewBag.EndDate })"
           class="px-6 py-3 bg-green-600 text-white rounded-xl hover:bg-green-700 transition-colors inline-flex items-center space-x-2">
            <i class="fas fa-file-excel"></i>
            <span>Export Excel</span>
        </a>
    </div>

    <!-- Search Form -->
    <form asp-controller="Discharges" asp-action="IPD"
          class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-calendar-alt mr-2 text-green-600"></i>จากวันที่
                </label>
                <input type="date" name="start" class="input-field" value="@ViewBag.StartDate">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-calendar-alt mr-2 text-green-600"></i>ถึงวันที่
                </label>
                <input type="date" name="end" class="input-field" value="@ViewBag.EndDate">
            </div>
            <div>
                <button type="submit" class="w-full btn-primary bg-green-600 hover:bg-green-700">
                    <i class="fas fa-search mr-2"></i>ค้นหา
                </button>
            </div>
        </div>
    </form>
</div>


<!-- Data Table -->
<div class="bg-white rounded-3xl shadow-lg overflow-hidden">
    <div class="overflow-x-auto">
        <table id="dischargeTable" class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">ลำดับ
                    </th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                        ชื่อ-สกุล</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">สิทธิ์
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">HN</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">AN</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Admit
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">D/C
                        </th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider">
                            จำนวนเงิน</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fas fa-inbox text-4xl mb-3 text-gray-300"></i>
                                    <p>ไม่พบข้อมูลที่ค้นหา</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.Id</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@item.FullName</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.TreatmentRight</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.HN</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.AN</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.Admit</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.DCDate
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Amount)
                                    </td>
                                </tr>
                            }
                        }

                    </tbody>
                </table>

                @if (Model != null)
                {
                    <form id="ExportExcelIP" asp-action="ExportExcelIP" asp-route-start="@ViewBag.fSdate"
                          asp-route-end="@ViewBag.fEdate" asp-route-dep="@ViewBag.Coldep"></form>
                    <button type="submit" form="ExportExcelIP" class="btn btn-success btn-lg">Export To Excel</button>
                }


                @section Scripts {
                    @{
                        await Html.RenderPartialAsync("_ValidationScriptsPartial");
                    }
                    <script>
                                $(function () {
                                    $("#example1").DataTable({
                                        "responsive": true, "lengthChange": false, "autoWidth": false,
                                        "buttons": ["copy", "csv", "excel", "pdf", "print", "colvis"]
                                    }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
                                    $('#example2').DataTable({
                                        "paging": true,
                                        "lengthChange": false,
                                        "searching": false,
                                        "ordering": true,
                                        "info": true,
                                        "autoWidth": false,
                                        "responsive": true,
                                    });
                                });
                    </script>


                }
