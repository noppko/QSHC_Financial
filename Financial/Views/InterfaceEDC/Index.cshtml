@model System.Data.DataTable

@{
    ViewData["Title"] = "Upload File & Recent Records";
}

<h2 class="text-center text-primary">Upload File & Recent Records</h2>

<div class="container mt-4">
    <div class="card p-4 shadow-sm">
        <form asp-controller="InterfaceEDC" asp-action="UploadFile" method="post" enctype="multipart/form-data" class="mb-4">
            <div class="input-group">
                <input type="file" name="file" class="form-control" required>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div>

<div class="container mt-4">
    <div class="card p-4 shadow-sm">
        <h4 class="text-secondary">Latest 50 Records</h4>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Filename</th>
                        <th>Record</th>
                        <th>Data</th>
                        <th>Process Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count > 0)
                    {
                        @foreach (System.Data.DataRow row in Model.Rows)
                        {
                            <tr>
                                <td>@row["Filename"]</td>
                                <td>@row["Record"]</td>
                                <td>@row["Data"]</td>
                                <td>@row["ProcessStatus"]</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No records found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
